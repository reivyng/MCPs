# Configuración SQL Server MCP

# Servidor SQL Server
DB_SERVER=localhost
DB_PORT=1433

# Credenciales
DB_USER=sa
DB_PASSWORD=tu_contraseña_aqui

# Base de datos por defecto
DB_NAME=master

# Opciones de conexión
DB_ENCRYPT=false
DB_TRUST_CERT=true

# Para conexiones a Azure SQL Server, usa:
# DB_ENCRYPT=true
# DB_TRUST_CERT=false
# DB_SERVER=nombreservidor.database.windows.net
